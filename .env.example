# Puerto y URL base del sistema
PORT=3000
APP_URL=http://localhost:3000

# Configuración de Base de Datos PostgreSQL
DB_USER=postgres
DB_PASSWORD=tu_contraseña
DB_HOST=localhost
DB_PORT=5432
DB_NAME=svt_db

# Configuración del Servidor de Correos (SMTP)
SMTP_HOST=mail.mspsalud.gob.ec
SMTP_PORT=587
SMTP_USER=formularios@mspsalud.gob.ec
SMTP_PASS=tu_contraseña_smtp
SMTP_FROM="Sistema de Validación Técnica MSP" <formularios@mspsalud.gob.ec>

# Configuración del Servidor de Entrada de Correos (IMAP) - Opcional
IMAP_HOST=mail.mspsalud.gob.ec
IMAP_PORT=993

# --- Seguridad / Sesiones (JWT) ---
# Genera un secreto largo y aleatorio. Imprescindible en producción.
# Ejemplo para generarlo: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio
# Duración del token de sesión en segundos (por defecto 8 horas).
JWT_TTL_SECONDS=28800

